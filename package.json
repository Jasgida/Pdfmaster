{

  "name": "pdfmaster",

  "version": "1.0.0",

  "description": "PDF management tool",

  "main": "server.js",

  "scripts": {

    "start": "node server.js",

    "build:css": "npx tailwindcss -i ./public/styles.css -o ./public/output.css --minify",

    "watch:css": "npx chokidar 'public/styles.css' -c 'npm run build:css'"

  },

  "dependencies": {

    "express": "^4.18.2",

    "multer": "^1.4.5-lts.1",

    "pdf-lib": "^1.17.1",

    "docx": "^8.5.0",

    "adm-zip": "^0.5.10"

  },

  "devDependencies": {

    "tailwindcss": "^3.4.1",

    "postcss": "^8.4.38",

    "autoprefixer": "^10.4.19",

    "chokidar-cli": "^3.0.0"

  }

}
